# Preferred hosted database: Neon
# DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require"

# Local Docker fallback
POSTGRES_DB=mirev
POSTGRES_USER=mirev
POSTGRES_PASSWORD=mirev
DATABASE_URL=postgresql://mirev:mirev@localhost:5432/mirev?schema=public

# Optional Solana config
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_PHANTOM_APP_ID=

# Required for server-side wallet portfolio reads via Helius
HELIUS_API_KEY=your_helius_api_key
